# Stages — environment template
# Copy this file to .env.local and fill in real values from your Supabase project's
# API settings page (https://supabase.com/dashboard → Project Settings → API).
#
# These NEXT_PUBLIC_* vars are bundled into the browser, which is intended:
# the publishable key is paired with Row Level Security for actual access control.
# Do NOT put service-role / sb_secret_* keys here — those bypass RLS and must
# stay server-side only.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
